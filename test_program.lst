program_factorial:
func_computeFact:
    t1 = x <= 1
    IFFALSE t1 GOTO L1
    f = 1
    GOTO L2
L1:
    t2 = x - 1
    PARAM t2
    t3 = CALL computeFact, 1
    t4 = x * t3
    f = t4
L2:
    computeFact = f
    RETURN computeFact
main:
    WRITE 'Enter a number: '
    READ n
    PARAM n
    t5 = CALL computeFact, 1
    result = t5
    WRITE 'Factorial = '
    WRITE result
    RETURN 