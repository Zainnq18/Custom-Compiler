   1  |  ! Sample program in the Option-1 language
   2  |  program factorial;
   3  |  
   4  |  var
   5  |      n : integer;
   6  |      result : integer;
   7  |  
   8  |  function computeFact(x : integer) : integer;
   9  |  var
  10  |      f : integer;
  11  |  begin
  12  |      if x <= 1 then
  13  |          f := 1
  14  |      else
  15  |          f := x * computeFact(x - 1);
  16  |      computeFact := f
  17  |  end;
  18  |  
  19  |  begin
  20  |      write('Enter a number: ');
  21  |      read(n);
  22  |      result := computeFact(n);
  23  |      write('Factorial = ');
  24  |      write(result)
  25  |  end.

